nce","permalink":"/cli"}},{"id":"guides/memory","title":"Memory","description":"Fort stores knowledge in a graph-based memory system backed by SQLite. The graph consists of typed nodes connected by edges, enabling rich relational queries across everything Fort learns.","source":"@site/docs/guides/memory.md","sourceDirName":"guides","slug":"/guides/memory","permalink":"/guides/memory","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Memory"},"sidebar":"docs","previous":{"title":"LLM Integration","permalink":"/guides/llm"},"next":{"title":"Threads","permalink":"/guides/threads"}},{"id":"guides/permissions","title":"Permissions","description":"Tiered action model for controlling what Fort can do autonomously","source":"@site/docs/guides/permissions.md","sourceDirName":"guides","slug":"/guides/permissions","permalink":"/guides/permissions","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":10,"frontMatter":{"sidebar_position":10,"title":"Permissions","description":"Tiered action model for controlling what Fort can do autonomously"},"sidebar":"docs","previous":{"title":"Tools","permalink":"/guides/tools"},"next":{"title":"Feature Flags","permalink":"/guides/feature-flags"}},{"id":"guides/plugins","title":"Plugins","description":"Plugin system with security scanning and sandboxed execution","source":"@site/docs/guides/plugins.md","sourceDirName":"guides","slug":"/guides/plugins","permalink":"/guides/plugins","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":12,"frontMatter":{"sidebar_position":12,"title":"Plugins","description":"Plugin system with security scanning and sandboxed execution"},"sidebar":"docs","previous":{"title":"Feature Flags","permalink":"/guides/feature-flags"},"next":{"title":"Self-Coding","permalink":"/guides/self-coding"}},{"id":"guides/rewind","title":"Rewind","description":"Snapshot-based backup and restore for Fort s